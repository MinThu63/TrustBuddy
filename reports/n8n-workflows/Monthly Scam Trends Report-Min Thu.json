      "parameters": {
        "jsCode": "const items = $input.all();\n\nlet summary = `Total scam checks logged: ${items.length}\\n\\n`;\nsummary += `Here is the raw data:\\n\\n`;\n\nitems.forEach((item, i) => {\n    const d = item.json;\n    summary += `Entry ${i + 1}:\\n`;\n    summary += `- Date: ${d['Timestamp'] || 'N/A'}\\n`;\n    summary += `- Message: ${d['User Message'] || 'N/A'}\\n`;\n    summary += `- Category: ${d['Scam Category'] || 'N/A'}\\n`;\n    summary += `- Risk Level: ${d['Risk Level'] || 'N/A'}\\n`;\n    summary += `- Entities: ${d['Extracted Entities'] || 'N/A'}\\n`;\n    summary += `- Action: ${d['Action Required'] || 'N/A'}\\n`;\n    summary += `- AI Verdict: ${d['AI Verdict'] || 'N/A'}\\n\\n`;\n});\n\nreturn [{ json: { scam_data: summary } }];\n"
      },
